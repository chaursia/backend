<%- include('partials/head') %>
<div class="flex h-screen overflow-hidden">
    <%- include('partials/sidebar') %>
    <main class="ml-64 flex-1 p-8 bg-gray-50 flex flex-col overflow-hidden">
        <div class="mb-4 flex items-center justify-between flex-shrink-0">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Server Logs</h1>
                <p class="text-gray-500 text-sm mt-1">Live captured terminal output <span id="liveDot" class="inline-block w-2 h-2 rounded-full bg-green-500 ml-1"></span></p>
            </div>
            <div class="flex gap-2">
                <button onclick="location.reload()" class="inline-flex items-center gap-2 bg-white hover:bg-gray-50 text-gray-700 text-sm font-semibold px-4 py-2 rounded-xl transition-colors shadow-sm border border-gray-200">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2v6h-6"/><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 2v6h6"/></svg>
                    Refresh
                </button>
                <button onclick="clearLogs()" class="inline-flex items-center gap-2 bg-white hover:bg-red-50 text-red-600 text-sm font-semibold px-4 py-2 rounded-xl transition-colors shadow-sm border border-gray-200">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                    Clear
                </button>
            </div>
        </div>

        <div class="flex-1 bg-gray-900 rounded-xl shadow-inner border border-gray-800 overflow-hidden flex flex-col min-h-0">
            <div class="bg-gray-950 px-4 py-2 border-b border-gray-800 flex items-center gap-2 flex-shrink-0">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-amber-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="ml-2 text-xs font-mono text-gray-500">Node.js stdout/stderr</span>
                <span id="logCount" class="ml-auto text-xs font-mono text-gray-600">0 logs</span>
            </div>
            
            <div class="flex-1 overflow-y-auto p-4 font-mono text-xs text-gray-300 whitespace-pre-wrap font-medium min-h-0" id="terminalBox">
                <% if (!logs || logs.length === 0) { %>
                    <div id="emptyMsg" class="text-gray-600 italic">No logs captured yet since the server started.</div>
                <% } else { %>
                    <% logs.slice().reverse().forEach(log => { 
                        let colorClass = 'text-blue-400';
                        if (log.type === 'ERROR') colorClass = 'text-red-400 font-bold';
                        if (log.type === 'WARN') colorClass = 'text-amber-400';
                    %>
                    <div class="mb-0.5 hover:bg-gray-800/50 px-1 -mx-1 rounded leading-snug">
                        <span class="text-gray-500">[<%= log.timestamp.toISOString().substring(11,19) %>]</span> 
                        <span class="<%= colorClass %>">[<%= log.type %>]</span> 
                        <span class="text-gray-200"><%= log.message %></span>
                    </div>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </main>
</div>

<script>
    let polling = false;

    function renderLogs(logs) {
        const box = document.getElementById('terminalBox');
        const count = document.getElementById('logCount');
        if (!logs || logs.length === 0) {
            box.innerHTML = '<div id="emptyMsg" class="text-gray-600 italic">No logs captured yet since the server started.</div>';
            count.textContent = '0 logs';
            return;
        }
        let html = '';
        for (let i = logs.length - 1; i >= 0; i--) {
            const log = logs[i];
            let colorClass = 'text-blue-400';
            if (log.type === 'ERROR') colorClass = 'text-red-400 font-bold';
            if (log.type === 'WARN') colorClass = 'text-amber-400';
            const time = log.timestamp ? log.timestamp.substring(11, 19) : '--:--:--';
            html += '<div class="mb-0.5 hover:bg-gray-800/50 px-1 -mx-1 rounded leading-snug">' +
                '<span class="text-gray-500">[' + time + ']</span> ' +
                '<span class="' + colorClass + '">[' + log.type + ']</span> ' +
                '<span class="text-gray-200">' + escapeHtml(log.message) + '</span></div>';
        }
        box.innerHTML = html;
        count.textContent = logs.length + ' logs';
        box.scrollTop = box.scrollHeight;
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function clearLogs() {
        if (!confirm('Clear all captured logs?')) return;
        fetch('/admin/server-logs/clear', { method: 'POST' }).then(() => {
            document.getElementById('terminalBox').innerHTML = '<div id="emptyMsg" class="text-gray-600 italic">No logs captured yet since the server started.</div>';
            document.getElementById('logCount').textContent = '0 logs';
        });
    }

    function pollLogs() {
        if (polling) return;
        polling = true;
        fetch('/admin/server-logs/data')
            .then(r => r.json())
            .then(data => { renderLogs(data.logs || []); })
            .catch(() => {})
            .finally(() => { polling = false; });
    }

    setInterval(pollLogs, 3000);

    const box = document.getElementById('terminalBox');
    if (box) box.scrollTop = box.scrollHeight;
</script>
</body>
</html>
