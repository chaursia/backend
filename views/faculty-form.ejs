<%- include('partials/head', { title: faculty ? 'Edit Faculty' : 'Add Faculty' }) %>
<%- include('partials/sidebar', { active: 'faculty' }) %>

<main class="main-content">
    <div class="page-header">
        <h1><%= faculty ? 'Edit Faculty' : 'Add Faculty' %></h1>
        <a href="/admin/faculty" class="btn btn-secondary">Back to List</a>
    </div>

    <% if (locals.flash) { %>
        <div class="flash flash-<%= flash.type %>"><%= flash.message %></div>
    <% } %>

    <div class="card">
        <form method="POST" action="<%= faculty ? '/admin/faculty/' + faculty.id : '/admin/faculty' %>" class="form-grid">
            <div class="form-group">
                <label for="employee_id">Employee ID <span class="required">*</span></label>
                <input type="text" id="employee_id" name="employee_id" value="<%= faculty ? faculty.employee_id : '' %>" required <%= faculty ? 'readonly' : '' %>>
            </div>

            <div class="form-group">
                <label for="name">Name <span class="required">*</span></label>
                <input type="text" id="name" name="name" value="<%= faculty ? faculty.name : '' %>" required>
            </div>

            <div class="form-group">
                <label for="designation">Designation</label>
                <input type="text" id="designation" name="designation" value="<%= faculty ? faculty.designation : '' %>" placeholder="e.g., Assistant Professor, Professor, HOD">
            </div>

            <div class="form-group">
                <label for="department">Department</label>
                <div style="display: flex; gap: 8px;">
                    <select id="department" name="department" class="form-input" style="flex: 1;">
                        <option value="">Select Department</option>
                        <% departments.forEach(d => { %>
                            <option value="<%= d %>" <%= faculty && faculty.department === d ? 'selected' : '' %>><%= d %></option>
                        <% }) %>
                        <option value="__new__">+ Add New Department</option>
                    </select>
                    <input type="text" id="new_department" name="new_department" placeholder="New department name" style="display: none; flex: 1;">
                </div>
            </div>

            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" value="<%= faculty ? faculty.email : '' %>">
            </div>

            <div class="form-group">
                <label for="phone">Phone</label>
                <input type="tel" id="phone" name="phone" value="<%= faculty ? faculty.phone : '' %>">
            </div>

            <div class="form-group">
                <label for="qualification">Qualification</label>
                <input type="text" id="qualification" name="qualification" value="<%= faculty ? faculty.qualification : '' %>" placeholder="e.g., PhD, M.Tech, M.Sc">
            </div>

            <div class="form-group">
                <label for="specialization">Specialization</label>
                <input type="text" id="specialization" name="specialization" value="<%= faculty ? faculty.specialization : '' %>" placeholder="e.g., Machine Learning, VLSI, Thermodynamics">
            </div>

            <div class="form-group" style="flex-direction: row; align-items: center;">
                <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                    <input type="checkbox" name="is_active" <%= (faculty ? faculty.is_active : true) ? 'checked' : '' %>> Active
                </label>
            </div>

            <div class="form-actions" style="grid-column: 1 / -1; display: flex; gap: 12px; margin-top: 16px;">
                <button type="submit" class="btn btn-primary"><%= faculty ? 'Update Faculty' : 'Create Faculty' %></button>
                <a href="/admin/faculty" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</main>

<script>
document.getElementById('department').addEventListener('change', function() {
    const newDeptInput = document.getElementById('new_department');
    if (this.value === '__new__') {
        newDeptInput.style.display = 'block';
        newDeptInput.required = true;
        this.required = false;
    } else {
        newDeptInput.style.display = 'none';
        newDeptInput.required = false;
        this.required = true;
    }
});

// Handle form submission to use new department value
document.querySelector('form').addEventListener('submit', function(e) {
    const deptSelect = document.getElementById('department');
    const newDeptInput = document.getElementById('new_department');
    if (deptSelect.value === '__new__' && newDeptInput.value.trim()) {
        // Create a hidden input with the new department value
        const hidden = document.createElement('input');
        hidden.type = 'hidden';
        hidden.name = 'department';
        hidden.value = newDeptInput.value.trim();
        this.appendChild(hidden);
        deptSelect.disabled = true; // Disable original so it doesn't send __new__
    }
});
</script>

<script src="/js/admin-common.js"></script>
</body>
</html>