<%- include('partials/head') %>
<div class="flex">
    <%- include('partials/sidebar') %>
    <main class="ml-64 flex-1 p-8 min-h-screen bg-gray-50">
        <div class="mb-8">
            <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
                <a href="/admin/faculty" class="hover:text-blue-600">Faculty</a>
                <span>/</span>
                <span class="text-gray-900 font-medium"><%= faculty ? 'Edit' : 'Add' %></span>
            </div>
            <h1 class="text-2xl font-bold text-gray-900"><%= faculty ? 'Edit Faculty' : 'Add Faculty' %></h1>
        </div>

        <% if (locals.flash) { %>
        <div class="mb-5 flex items-center gap-2 bg-green-100 border border-green-300 text-green-700 text-sm px-4 py-3 rounded-xl">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <%= flash.message %>
        </div>
        <% } %>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 max-w-2xl">
            <form method="POST" action="<%= faculty ? '/admin/faculty/' + faculty.id : '/admin/faculty' %>">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                    <div>
                        <label class="text-sm font-semibold text-gray-700 block mb-1.5">Employee ID <span class="text-red-500">*</span></label>
                        <input type="text" name="employee_id" value="<%= faculty ? faculty.employee_id : '' %>" required <%= faculty ? 'readonly' : '' %> class="w-full text-sm border border-gray-200 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400 <%= faculty ? 'bg-gray-50 text-gray-500' : '' %>">
                    </div>
                    <div>
                        <label class="text-sm font-semibold text-gray-700 block mb-1.5">Name <span class="text-red-500">*</span></label>
                        <input type="text" name="name" value="<%= faculty ? faculty.name : '' %>" required class="w-full text-sm border border-gray-200 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400">
                    </div>
                    <div>
                        <label class="text-sm font-semibold text-gray-700 block mb-1.5">Designation</label>
                        <input type="text" name="designation" value="<%= faculty ? faculty.designation : '' %>" placeholder="e.g., Professor, HOD" class="w-full text-sm border border-gray-200 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400">
                    </div>
                    <div>
                        <label class="text-sm font-semibold text-gray-700 block mb-1.5">Department</label>
                        <input type="text" name="department" value="<%= faculty ? faculty.department : '' %>" placeholder="e.g., Computer Science" class="w-full text-sm border border-gray-200 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400">
                    </div>
                    <div>
                        <label class="text-sm font-semibold text-gray-700 block mb-1.5">Email</label>
                        <input type="email" name="email" value="<%= faculty ? faculty.email : '' %>" class="w-full text-sm border border-gray-200 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400">
                    </div>
                    <div>
                        <label class="text-sm font-semibold text-gray-700 block mb-1.5">Phone</label>
                        <input type="tel" name="phone" value="<%= faculty ? faculty.phone : '' %>" class="w-full text-sm border border-gray-200 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400">
                    </div>
                    <div>
                        <label class="text-sm font-semibold text-gray-700 block mb-1.5">Qualification</label>
                        <input type="text" name="qualification" value="<%= faculty ? faculty.qualification : '' %>" placeholder="e.g., PhD, M.Tech" class="w-full text-sm border border-gray-200 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400">
                    </div>
                    <div>
                        <label class="text-sm font-semibold text-gray-700 block mb-1.5">Specialization</label>
                        <input type="text" name="specialization" value="<%= faculty ? faculty.specialization : '' %>" placeholder="e.g., Machine Learning" class="w-full text-sm border border-gray-200 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400">
                    </div>
                    <div class="sm:col-span-2">
                        <label class="text-sm font-semibold text-gray-700 block mb-1.5">Profile Image URL</label>
                        <input type="url" name="profile_image" value="<%= faculty ? faculty.profile_image : '' %>" placeholder="https://example.com/photo.jpg" class="w-full text-sm border border-gray-200 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400">
                        <% if (faculty && faculty.profile_image) { %>
                            <div class="mt-2 flex items-center gap-3">
                                <img src="<%= faculty.profile_image %>" alt="" class="w-10 h-10 rounded-full object-cover border border-gray-200">
                                <span class="text-xs text-gray-400 truncate max-w-xs"><%= faculty.profile_image %></span>
                            </div>
                        <% } %>
                    </div>
                    <div class="flex items-center">
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="checkbox" name="is_active" <%= (faculty ? faculty.is_active : true) ? 'checked' : '' %> class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500">
                            <span class="text-sm font-semibold text-gray-700">Active</span>
                        </label>
                    </div>
                </div>

                <div class="flex gap-3 mt-8 pt-6 border-t border-gray-100">
                    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-6 py-2.5 rounded-xl transition-colors shadow-sm">
                        <%= faculty ? 'Update Faculty' : 'Create Faculty' %>
                    </button>
                    <a href="/admin/faculty" class="bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium px-6 py-2.5 rounded-xl transition-colors">Cancel</a>
                </div>
            </form>
        </div>
    </main>
</div>

</body>
</html>