<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Admin Profile | ITS College</title>
</head>
<body class="bg-gray-50 font-sans">
    <div class="flex">
        <%- include('partials/sidebar') %>

        <main class="flex-1 ml-64 p-8">
            <!-- Header -->
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h1 class="text-2xl font-bold text-gray-900">Admin Profile</h1>
                    <p class="text-gray-500 mt-1">Manage your public identity on the student Social Hub.</p>
                </div>
                <div class="flex gap-3">
                    <a href="/admin" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
                        Back to Dashboard
                    </a>
                </div>
            </div>

            <% if (typeof flash !== 'undefined' && flash) { %>
                <div class="mb-6 p-4 rounded-lg <%= flash.type === 'success' ? 'bg-green-50 text-green-700 border border-green-200' : 'bg-red-50 text-red-700 border border-red-200' %>">
                    <%= flash.message %>
                </div>
            <% } %>

            <div class="max-w-4xl">
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                    <div class="p-8">
                        <form action="/admin/profile" method="POST" enctype="multipart/form-data" class="space-y-8">
                            
                            <!-- Profile Section -->
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                                <div class="space-y-4">
                                    <label class="block text-sm font-semibold text-gray-700 uppercase tracking-wider">Public Identity</label>
                                    <div class="relative group">
                                        <div class="w-32 h-32 rounded-2xl bg-blue-50 border-2 border-dashed border-blue-200 flex items-center justify-center overflow-hidden">
                                            <% if (adminItem && adminItem.profile_image) { %>
                                                <img src="<%= adminItem.profile_image %>" alt="Admin Avatar" class="w-full h-full object-cover">
                                            <% } else { %>
                                                <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-blue-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                            <% } %>
                                        </div>
                                        <label for="profileImage" class="absolute inset-0 w-32 h-32 rounded-2xl bg-black bg-opacity-0 group-hover:bg-opacity-40 flex items-center justify-center cursor-pointer transition-all duration-300">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white opacity-0 group-hover:opacity-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></label>
                                        <input type="file" id="profileImage" name="profileImage" class="hidden" accept="image/*">
                                    </div>
                                    <p class="text-xs text-gray-400">Recommended: Square PNG/JPG, max 5MB.</p>
                                </div>

                                <div class="md:col-span-2 space-y-6">
                                    <div>
                                        <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Display Name</label>
                                        <input type="text" id="name" name="name" value="<%= adminItem ? adminItem.name : 'Official Admin' %>" required
                                            class="w-full px-4 py-2.5 bg-gray-50 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all"
                                            placeholder="e.g. ITS Official Admin">
                                        <p class="mt-2 text-xs text-gray-500 italic">This name will be shown on all official posts in the student mobile app.</p>
                                    </div>

                                    <div class="bg-blue-50 p-4 rounded-lg flex gap-3 border border-blue-100">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                                        <p class="text-sm text-blue-700 leading-relaxed">
                                            Changing your identity here will instantly update the author information for all past and future posts made from the Admin Panel.
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <!-- Footer -->
                            <div class="pt-6 border-t border-gray-100 flex justify-end">
                                <button type="submit" class="px-8 py-2.5 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 shadow-md transition-all">
                                    Save Profile Changes
                                </button>
                            </div>

                        </form>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
