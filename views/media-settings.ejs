<%- include('partials/head') %>
<div class="flex">
    <%- include('partials/sidebar') %>
    <main class="ml-64 flex-1 p-8 min-h-screen bg-gray-50">
        <div class="mb-8">
            <h1 class="text-2xl font-bold text-gray-900">Media Settings</h1>
            <p class="text-gray-500 text-sm mt-1">Configure upload services for social feed posts</p>
        </div>

        <% if (locals.flash) { %>
        <div class="mb-5 px-4 py-3 rounded-xl text-sm font-medium <%= flash.type === 'success' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>"><%= flash.message %></div>
        <% } %>

        <div class="space-y-6 max-w-2xl">
            <!-- Byse.sx -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
                <h2 class="text-lg font-bold text-gray-900 mb-1">Byse.sx — Video Uploads</h2>
                <p class="text-xs text-gray-400 mb-5">Used for uploading videos to social feed posts</p>
                <form method="POST" action="/admin/media-settings">
                    <div class="mb-5">
                        <label class="text-sm font-medium text-gray-700 block mb-1.5">API Key</label>
                        <input type="password" name="byse_api_key" value="<%= byseApiKey %>" class="w-full text-sm border border-gray-200 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500/30">
                        <p class="text-xs text-gray-400 mt-1.5">Get your API key from <a href="https://byse.sx" target="_blank" class="text-blue-500 hover:underline">byse.sx</a></p>
                    </div>
                    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-6 py-2.5 rounded-xl transition-colors">Save Settings</button>
                </form>
            </div>

            <!-- FileLu -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
                <h2 class="text-lg font-bold text-gray-900 mb-1">FileLu — Document Uploads</h2>
                <p class="text-xs text-gray-400 mb-5">Used for uploading PDFs and documents to social feed posts</p>
                <form method="POST" action="/admin/media-settings/filelu">
                    <div class="mb-5">
                        <label class="text-sm font-medium text-gray-700 block mb-1.5">API Key</label>
                        <input type="password" name="filelu_api_key" value="<%= fileluApiKey %>" class="w-full text-sm border border-gray-200 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500/30">
                        <p class="text-xs text-gray-400 mt-1.5">Get your API key from <a href="https://filelu.com/account/" target="_blank" class="text-blue-500 hover:underline">filelu.com/account</a></p>
                    </div>
                    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-6 py-2.5 rounded-xl transition-colors">Save Settings</button>
                </form>
            </div>
        </div>
    </main>
</div>
</body>
</html>
