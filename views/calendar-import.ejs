<%- include('partials/head') %>
<div class="flex">
    <%- include('partials/sidebar') %>
    <main class="ml-64 flex-1 p-8 min-h-screen bg-gray-50">
        <div class="mb-8">
            <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
                <a href="/admin/calendar" class="hover:text-blue-600">Calendar</a>
                <span>/</span>
                <span class="text-gray-900 font-medium">Import JSON</span>
            </div>
            <h1 class="text-2xl font-bold text-gray-900">Import Calendar Events</h1>
        </div>

        <% if (locals.flash) { %>
        <div class="mb-5 flex items-center gap-2 <%= flash.type === 'success' ? 'bg-green-100 border-green-300 text-green-700' : 'bg-red-100 border-red-300 text-red-700' %> border text-sm px-4 py-3 rounded-xl">
            <%= flash.message %>
        </div>
        <% } %>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 max-w-2xl mb-6">
            <h3 class="text-lg font-bold text-gray-900 mb-3">JSON Format</h3>
            <p class="text-sm text-gray-600 mb-3">Required fields: <code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs font-mono">title</code>, <code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs font-mono">date</code>. Optional: <code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs font-mono">description</code>, <code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs font-mono">type</code> (general, holiday, exam, event).</p>
            <pre class="bg-gray-900 text-gray-100 text-xs rounded-xl p-4 overflow-x-auto"><code>[
  {
    "title": "Independence Day",
    "date": "2025-08-15",
    "description": "National holiday",
    "type": "holiday"
  },
  {
    "title": "Mid Semester Exam",
    "date": "2025-09-10",
    "description": "Mid semester examinations begin",
    "type": "exam"
  }
]</code></pre>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 max-w-2xl">
            <form method="POST" action="/admin/calendar/import">
                <div>
                    <label class="text-sm font-semibold text-gray-700 block mb-1.5">JSON Data <span class="text-red-500">*</span></label>
                    <textarea name="jsonData" rows="15" class="w-full text-sm font-mono border border-gray-200 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400" required></textarea>
                </div>
                <button type="submit" class="mt-5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-6 py-2.5 rounded-xl transition-colors shadow-sm">Import Events</button>
            </form>
        </div>
    </main>
</div>

</body>
</html>