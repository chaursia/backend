<%- include('partials/head') %>
<style>
    .net-line { transition: stroke 0.5s ease; }
</style>
<div class="flex">
    <%- include('partials/sidebar') %>
    <main class="ml-64 flex-1 p-8 min-h-screen bg-gray-50">
        <div class="mb-8">
            <h1 class="text-2xl font-bold text-gray-900">System Health</h1>
            <p class="text-gray-500 text-sm mt-1">Live status of all connected services</p>
        </div>

        <!-- Network Architecture Diagram -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
            <h2 class="font-semibold text-gray-900 mb-4">Network Architecture</h2>
            <div class="relative w-full overflow-x-auto">
                <svg viewBox="0 0 1100 280" class="w-full max-w-5xl" xmlns="http://www.w3.org/2000/svg">
                    <!-- connection lines -->
                    <% const lineColor = (s) => s === 'connected' || s === 'reachable' || s === 'configured' ? '#22c55e' : (s === 'unconfigured' ? '#eab308' : '#ef4444'); %>
                    <line x1="150" y1="110" x2="300" y2="40" stroke="<%= lineColor(health.turso) %>" stroke-width="2.5" class="net-line" stroke-dasharray="6,3"/>
                    <line x1="150" y1="110" x2="300" y2="110" stroke="<%= lineColor(health.supabase) %>" stroke-width="2.5" class="net-line" stroke-dasharray="6,3"/>
                    <line x1="150" y1="110" x2="300" y2="180" stroke="<%= lineColor(health.smtp) %>" stroke-width="2.5" class="net-line" stroke-dasharray="6,3"/>
                    <line x1="150" y1="110" x2="550" y2="40" stroke="<%= lineColor(health.cloudinary.status) %>" stroke-width="2.5" class="net-line" stroke-dasharray="6,3"/>
                    <line x1="150" y1="110" x2="550" y2="110" stroke="<%= lineColor(health.collegeApi.status) %>" stroke-width="2.5" class="net-line" stroke-dasharray="6,3"/>
                    <line x1="150" y1="110" x2="550" y2="180" stroke="<%= lineColor(health.collegeInfo.status) %>" stroke-width="2.5" class="net-line" stroke-dasharray="6,3"/>
                    <line x1="150" y1="110" x2="800" y2="85" stroke="<%= lineColor(health.byse.status) %>" stroke-width="2.5" class="net-line" stroke-dasharray="6,3"/>
                    <line x1="150" y1="110" x2="800" y2="155" stroke="<%= lineColor(health.b2.status) %>" stroke-width="2.5" class="net-line" stroke-dasharray="6,3"/>

                    <!-- Node: Server -->
                    <rect x="20" y="85" width="130" height="50" rx="10" fill="#1e293b"/>
                    <text x="85" y="112" text-anchor="middle" fill="white" font-size="13" font-weight="bold">ITS Backend Server</text>
                    <text x="85" y="126" text-anchor="middle" fill="#94a3b8" font-size="10"><%= health.uptime %></text>

                    <!-- Node: Turso -->
                    <rect x="300" y="15" width="120" height="50" rx="10" fill="<%= health.turso === 'connected' ? '#dcfce7' : '#fee2e2' %>" stroke="<%= lineColor(health.turso) %>" stroke-width="2"/>
                    <text x="360" y="42" text-anchor="middle" fill="<%= health.turso === 'connected' ? '#16a34a' : '#dc2626' %>" font-size="13" font-weight="bold">Turso DB</text>
                    <text x="360" y="56" text-anchor="middle" fill="#64748b" font-size="10"><%= health.turso === 'connected' ? 'Connected' : 'Error' %></text>

                    <!-- Node: Supabase -->
                    <rect x="300" y="85" width="120" height="50" rx="10" fill="<%= health.supabase === 'connected' ? '#dcfce7' : '#fee2e2' %>" stroke="<%= lineColor(health.supabase) %>" stroke-width="2"/>
                    <text x="360" y="112" text-anchor="middle" fill="<%= health.supabase === 'connected' ? '#16a34a' : '#dc2626' %>" font-size="13" font-weight="bold">Supabase</text>
                    <text x="360" y="126" text-anchor="middle" fill="#64748b" font-size="10"><%= health.supabase === 'connected' ? 'Connected' : 'Error' %></text>

                    <!-- Node: SMTP -->
                    <rect x="300" y="155" width="120" height="50" rx="10" fill="<%= health.smtp === 'connected' ? '#dcfce7' : (health.smtp === 'unconfigured' ? '#fef9c3' : '#fee2e2') %>" stroke="<%= health.smtp === 'connected' ? '#22c55e' : (health.smtp === 'unconfigured' ? '#eab308' : '#ef4444') %>" stroke-width="2"/>
                    <text x="360" y="180" text-anchor="middle" fill="<%= health.smtp === 'connected' ? '#16a34a' : (health.smtp === 'unconfigured' ? '#ca8a04' : '#dc2626') %>" font-size="13" font-weight="bold">Gmail SMTP</text>
                    <text x="360" y="194" text-anchor="middle" fill="#64748b" font-size="10"><%= health.smtp.charAt(0).toUpperCase() + health.smtp.slice(1) %></text>

                    <!-- Node: Cloudinary -->
                    <% const cldStat = health.cloudinary?.status; const cldOk = cldStat === 'connected'; const cldUncfg = cldStat === 'unconfigured'; %>
                    <rect x="550" y="15" width="130" height="50" rx="10" fill="<%= cldOk ? '#dcfce7' : (cldUncfg ? '#fef9c3' : '#fee2e2') %>" stroke="<%= lineColor(cldStat) %>" stroke-width="2"/>
                    <text x="615" y="42" text-anchor="middle" fill="<%= cldOk ? '#16a34a' : (cldUncfg ? '#ca8a04' : '#dc2626') %>" font-size="13" font-weight="bold">Cloudinary</text>
                    <text x="615" y="56" text-anchor="middle" fill="#64748b" font-size="10"><%= cldOk ? 'Connected' : (cldUncfg ? 'Unconfigured' : 'Error') %></text>

                    <!-- Node: College API -->
                    <rect x="550" y="85" width="130" height="50" rx="10" fill="<%= health.collegeApi?.status === 'reachable' ? '#dcfce7' : '#fee2e2' %>" stroke="<%= lineColor(health.collegeApi?.status) %>" stroke-width="2"/>
                    <text x="615" y="112" text-anchor="middle" fill="<%= health.collegeApi?.status === 'reachable' ? '#16a34a' : '#dc2626' %>" font-size="13" font-weight="bold">College ERP API</text>
                    <text x="615" y="126" text-anchor="middle" fill="#64748b" font-size="10"><%= health.collegeApi?.status === 'reachable' ? `HTTP ${health.collegeApi.code}` : (health.collegeApi?.status || 'Unreachable') %></text>

                    <!-- Node: Other ERP -->
                    <rect x="550" y="155" width="130" height="50" rx="10" fill="<%= health.collegeInfo?.status === 'reachable' ? '#dcfce7' : '#fee2e2' %>" stroke="<%= lineColor(health.collegeInfo?.status) %>" stroke-width="2"/>
                    <text x="615" y="180" text-anchor="middle" fill="<%= health.collegeInfo?.status === 'reachable' ? '#16a34a' : '#dc2626' %>" font-size="13" font-weight="bold">College Info</text>
                    <text x="615" y="194" text-anchor="middle" fill="#64748b" font-size="10"><%= health.collegeInfo?.status === 'reachable' ? `HTTP ${health.collegeInfo.code}` : (health.collegeInfo?.status || 'Unreachable') %></text>

                    <!-- Node: Byse -->
                    <% const bsStat = health.byse?.status; const bsOk = bsStat === 'configured'; const bsUncfg = bsStat === 'unconfigured'; %>
                    <rect x="800" y="60" width="120" height="50" rx="10" fill="<%= bsOk ? '#dcfce7' : (bsUncfg ? '#fef9c3' : '#fee2e2') %>" stroke="<%= lineColor(bsStat) %>" stroke-width="2"/>
                    <text x="860" y="87" text-anchor="middle" fill="<%= bsOk ? '#16a34a' : (bsUncfg ? '#ca8a04' : '#dc2626') %>" font-size="13" font-weight="bold">Byse.sx</text>
                    <text x="860" y="101" text-anchor="middle" fill="#64748b" font-size="10"><%= bsOk ? 'Configured' : (bsUncfg ? 'Unconfigured' : 'Error') %></text>

                    <!-- Node: B2 -->
                    <% const b2Stat = health.b2?.status; const b2Ok = b2Stat === 'configured'; const b2Uncfg = b2Stat === 'unconfigured'; %>
                    <rect x="800" y="130" width="120" height="50" rx="10" fill="<%= b2Ok ? '#dcfce7' : (b2Uncfg ? '#fef9c3' : '#fee2e2') %>" stroke="<%= lineColor(b2Stat) %>" stroke-width="2"/>
                    <text x="860" y="157" text-anchor="middle" fill="<%= b2Ok ? '#16a34a' : (b2Uncfg ? '#ca8a04' : '#dc2626') %>" font-size="13" font-weight="bold">Backblaze B2</text>
                    <text x="860" y="171" text-anchor="middle" fill="#64748b" font-size="10"><%= b2Ok ? 'Configured' : (b2Uncfg ? 'Unconfigured' : 'Error') %></text>
                </svg>
            </div>
        </div>

        <!-- Status Cards -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-5 mb-6">
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                <div class="flex items-center justify-between mb-4">
                    <div class="w-10 h-10 rounded-xl bg-<%= health.turso === 'connected' ? 'green' : 'red' %>-100 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-<%= health.turso === 'connected' ? 'green' : 'red' %>-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4.03 3-9 3S3 13.66 3 12"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/></svg>
                    </div>
                    <span class="w-2.5 h-2.5 rounded-full bg-<%= health.turso === 'connected' ? 'green' : 'red' %>-500 animate-<%= health.turso === 'connected' ? 'pulse' : 'none' %>"></span>
                </div>
                <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Turso DB</div>
                <div class="text-lg font-bold text-<%= health.turso === 'connected' ? 'green' : 'red' %>-600 capitalize"><%= health.turso %></div>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                <div class="flex items-center justify-between mb-4">
                    <div class="w-10 h-10 rounded-xl bg-<%= health.supabase === 'connected' ? 'green' : 'red' %>-100 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-<%= health.supabase === 'connected' ? 'green' : 'red' %>-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    </div>
                    <span class="w-2.5 h-2.5 rounded-full bg-<%= health.supabase === 'connected' ? 'green' : 'red' %>-500"></span>
                </div>
                <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Supabase</div>
                <div class="text-lg font-bold text-<%= health.supabase === 'connected' ? 'green' : 'red' %>-600 capitalize"><%= health.supabase %></div>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                <div class="flex items-center justify-between mb-4">
                    <% 
                        let smtpColor = 'red';
                        if (health.smtp === 'connected') smtpColor = 'green';
                        if (health.smtp === 'unconfigured') smtpColor = 'amber';
                    %>
                    <div class="w-10 h-10 rounded-xl bg-<%= smtpColor %>-100 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-<%= smtpColor %>-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    </div>
                    <span class="w-2.5 h-2.5 rounded-full bg-<%= smtpColor %>-500 animate-<%= health.smtp === 'connected' ? 'pulse' : 'none' %>"></span>
                </div>
                <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Gmail SMTP</div>
                <div class="text-lg font-bold text-<%= smtpColor %>-600 capitalize"><%= health.smtp %></div>
                <div class="text-[10px] text-gray-400 truncate mt-1"><%= health.smtpMessage %></div>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                <div class="flex items-center justify-between mb-4">
                    <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    <span class="w-2.5 h-2.5 rounded-full bg-green-500 animate-pulse"></span>
                </div>
                <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Server Uptime</div>
                <div class="text-lg font-bold text-blue-600"><%= health.uptime %></div>
            </div>
        </div>

        <!-- College ERP Endpoints -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
            <h2 class="font-semibold text-gray-900 mb-5">College ERP Endpoints</h2>
            <div class="space-y-3">
                    <% const erpEndpoints = [
                    { name: 'Base API', key: 'collegeApi', path: '/' },
                    { name: 'College Info', key: 'collegeInfo', path: '/college/information' },
                ] %>
                <% erpEndpoints.forEach(ep => { %>
                    <% const st = health[ep.key] || { status: 'unknown', code: null }; %>
                    <div class="flex items-center justify-between py-3 px-4 rounded-xl <%= st.status === 'reachable' ? 'bg-green-50' : 'bg-red-50' %>">
                        <div class="flex items-center gap-3">
                            <span class="w-2.5 h-2.5 rounded-full <%= st.status === 'reachable' ? 'bg-green-500' : 'bg-red-500' %>"></span>
                            <div>
                                <div class="text-sm font-medium text-gray-900"><%= ep.name %></div>
                                <div class="text-xs text-gray-500 font-mono"><%= ep.path %></div>
                            </div>
                        </div>
                        <div class="flex items-center gap-3">
                            <% if (st.code) { %>
                                <span class="text-xs font-mono <%= st.code >= 200 && st.code < 400 ? 'text-green-600' : 'text-red-600' %>">HTTP <%= st.code %></span>
                            <% } %>
                            <span class="text-sm font-medium <%= st.status === 'reachable' ? 'text-green-600' : 'text-red-600' %> capitalize"><%= st.status %></span>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- Media Services & Stats -->
        <div class="grid grid-cols-1 md:grid-cols-5 gap-5 mb-6">
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                <%
                    let cldColor = 'red';
                    let cldLabel = health.cloudinary?.status || 'Unknown';
                    if (health.cloudinary?.status === 'connected') { cldColor = 'green'; cldLabel = 'Connected'; }
                    if (health.cloudinary?.status === 'unconfigured') { cldColor = 'amber'; cldLabel = 'Unconfigured'; }
                %>
                <div class="flex items-center justify-between mb-4">
                    <div class="w-10 h-10 rounded-xl bg-<%= cldColor %>-100 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-<%= cldColor %>-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.5 20H7a5 5 0 0 1-4.5-7.5A5 5 0 0 1 7 7h.5A7 7 0 0 1 19 9.5"/><path d="M16 14v6"/><path d="M19 17h-6"/></svg>
                    </div>
                    <span class="w-2.5 h-2.5 rounded-full bg-<%= cldColor %>-500 <%= health.cloudinary?.status === 'connected' ? 'animate-pulse' : '' %>"></span>
                </div>
                <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Cloudinary</div>
                <div class="text-lg font-bold text-<%= cldColor %>-600 capitalize"><%= cldLabel %></div>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                <%
                    let bsColor = 'red';
                    let bsLabel = health.byse?.status || 'Unknown';
                    if (health.byse?.status === 'configured') { bsColor = 'green'; bsLabel = 'Configured'; }
                    if (health.byse?.status === 'unconfigured') { bsColor = 'amber'; bsLabel = 'Unconfigured'; }
                %>
                <div class="flex items-center justify-between mb-4">
                    <div class="w-10 h-10 rounded-xl bg-<%= bsColor %>-100 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-<%= bsColor %>-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
                    </div>
                    <span class="w-2.5 h-2.5 rounded-full bg-<%= bsColor %>-500 <%= health.byse?.status === 'configured' ? 'animate-pulse' : '' %>"></span>
                </div>
                <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Byse.sx</div>
                <div class="text-lg font-bold text-<%= bsColor %>-600 capitalize"><%= bsLabel %></div>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                <%
                    let b2Color = 'red';
                    let b2Label = health.b2?.status || 'Unknown';
                    if (health.b2?.status === 'configured') { b2Color = 'green'; b2Label = 'Configured'; }
                    if (health.b2?.status === 'unconfigured') { b2Color = 'amber'; b2Label = 'Unconfigured'; }
                %>
                <div class="flex items-center justify-between mb-4">
                    <div class="w-10 h-10 rounded-xl bg-<%= b2Color %>-100 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-<%= b2Color %>-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    </div>
                    <span class="w-2.5 h-2.5 rounded-full bg-<%= b2Color %>-500 <%= health.b2?.status === 'configured' ? 'animate-pulse' : '' %>"></span>
                </div>
                <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Backblaze B2</div>
                <div class="text-lg font-bold text-<%= b2Color %>-600 capitalize"><%= b2Label %></div>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                <div class="flex items-center justify-between mb-4">
                    <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </div>
                </div>
                <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Faculty Records</div>
                <div class="text-lg font-bold text-blue-600"><%= health.totalFaculty %></div>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                <div class="flex items-center justify-between mb-4">
                    <div class="w-10 h-10 rounded-xl bg-purple-100 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-purple-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="m9 16 2 2 4-4"/></svg>
                    </div>
                </div>
                <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">Calendar Events</div>
                <div class="text-lg font-bold text-purple-600"><%= health.totalCalendarEvents %></div>
            </div>
        </div>

        <!-- Environment Info -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
            <h2 class="font-semibold text-gray-900 mb-5">Environment</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="flex justify-between items-center py-3 border-b border-gray-50">
                    <span class="text-sm text-gray-500">Node.js Version</span>
                    <span class="text-sm font-mono font-medium text-gray-800"><%= health.nodeVersion %></span>
                </div>
                <div class="flex justify-between items-center py-3 border-b border-gray-50">
                    <span class="text-sm text-gray-500">Environment</span>
                    <span class="text-sm font-medium text-gray-800"><%= health.env %></span>
                </div>
                <div class="flex justify-between items-center py-3 border-b border-gray-50">
                    <span class="text-sm text-gray-500">Total Users</span>
                    <span class="text-sm font-mono font-medium text-gray-800"><%= health.totalUsers %></span>
                </div>
                <div class="flex justify-between items-center py-3 border-b border-gray-50">
                    <span class="text-sm text-gray-500">Social Posts</span>
                    <span class="text-sm font-mono font-medium text-gray-800"><%= health.totalSocialPosts %></span>
                </div>
                <div class="flex justify-between items-center py-3 border-b border-gray-50">
                    <span class="text-sm text-gray-500">Memory Usage</span>
                    <span class="text-sm font-mono font-medium text-gray-800"><%= health.memoryUsage %></span>
                </div>
                <div class="flex justify-between items-center py-3">
                    <span class="text-sm text-gray-500">Checked At</span>
                    <span class="text-sm font-mono font-medium text-gray-800"><%= health.checkedAt %></span>
                </div>
            </div>
        </div>
    </main>
</div>
</body>
</html>