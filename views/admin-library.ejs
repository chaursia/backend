<%- include('partials/head') %>
<div class="flex">
    <%- include('partials/sidebar') %>
    <main class="flex-1 ml-64 p-8 min-h-screen bg-gray-50">
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Library Management</h1>
                <p class="text-gray-500 text-sm mt-1">Upload, browse, and delete study documents</p>
            </div>
        </div>

        <% if (locals.flash) { %>
        <div class="mb-6 px-4 py-3 rounded-xl text-sm font-medium <%= flash.type === 'success' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>"><%= flash.message %></div>
        <% } %>

        <!-- Upload Form -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 mb-8 max-w-2xl">
            <h2 class="text-lg font-bold text-gray-900 mb-1">Upload Document</h2>
            <p class="text-xs text-gray-400 mb-5">Upload study material, notes, or any document to the Library</p>
            <form action="/admin/library/upload" method="POST" enctype="multipart/form-data" class="space-y-4">
                <div>
                    <label class="text-sm font-medium text-gray-700 block mb-1.5">Caption *</label>
                    <input type="text" name="caption" required
                           class="w-full text-sm border border-gray-200 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500/30"
                           placeholder="e.g. Maths Unit 1 Notes">
                </div>
                <div>
                    <label class="text-sm font-medium text-gray-700 block mb-1.5">File *</label>
                    <input type="file" name="document" required
                           class="w-full text-sm border border-gray-200 rounded-xl px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500/30 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100">
                </div>
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-6 py-2.5 rounded-xl transition-colors">Upload</button>
            </form>
        </div>

        <!-- Documents Table -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h2 class="text-lg font-bold text-gray-900">All Documents</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-gray-50 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">
                            <th class="px-6 py-3">Caption</th>
                            <th class="px-6 py-3">Uploaded By</th>
                            <th class="px-6 py-3">Type</th>
                            <th class="px-6 py-3">Size</th>
                            <th class="px-6 py-3">Date</th>
                            <th class="px-6 py-3 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        <% if (documents.length === 0) { %>
                        <tr><td colspan="6" class="px-6 py-12 text-center text-gray-400">No documents uploaded yet.</td></tr>
                        <% } %>
                        <% for (const doc of documents) { %>
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4 font-medium text-gray-900 max-w-xs truncate"><%= doc.caption %></td>
                            <td class="px-6 py-4 text-gray-600"><%= doc.user_name || 'Unknown' %></td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-1 text-xs font-medium bg-gray-100 text-gray-700 rounded-lg"><%= (doc.mime_type || 'application/octet-stream').split('/').pop().toUpperCase() %></span>
                            </td>
                            <td class="px-6 py-4 text-gray-500">
                                <% if (doc.file_size > 0) { %>
                                    <%= doc.file_size < 1024 ? doc.file_size + ' B' : doc.file_size < 1048576 ? (doc.file_size / 1024).toFixed(0) + ' KB' : (doc.file_size / 1048576).toFixed(1) + ' MB' %>
                                <% } else { %>-<% } %>
                            </td>
                            <td class="px-6 py-4 text-gray-500"><%= new Date(doc.created_at + 'Z').toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
                            <td class="px-6 py-4 text-right">
                                <form action="/admin/library/<%= doc.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Delete this document?')">
                                    <button type="submit" class="text-red-600 hover:text-red-800 text-sm font-medium transition-colors">Delete</button>
                                </form>
                            </td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
</body>
</html>
